# Flask Configuration

SECRET_KEY=your-secret-key-here-change-in-production

FLASK_ENV=production



# Database

DATABASE_URL=sqlite:///college_assistant.db



# Default Admin Credentials (for initial setup)

DEFAULT_ADMIN_USERNAME=admin

DEFAULT_ADMIN_EMAIL=admin@edubot.com

DEFAULT_ADMIN_PASSWORD=admin123

DEFAULT_ADMIN_ROLE=admin



# Twilio WhatsApp Configuration

TWILIO_ACCOUNT_SID=your_twilio_account_sid

TWILIO_AUTH_TOKEN=your_twilio_auth_token

TWILIO_WHATSAPP_FROM=whatsapp:+14155238886



# Email Configuration (for OTP)

MAIL_SERVER=smtp.gmail.com

MAIL_PORT=587

MAIL_USE_TLS=true

MAIL_USERNAME=your_email@gmail.com

MAIL_PASSWORD=your_app_password

MAIL_DEFAULT_SENDER=noreply@college.edu



# Admin Email for Weekly Reports

ADMIN_EMAIL=admin@college.edu



# OTP Configuration

OTP_EXPIRY_MINUTES=10



# Rate Limiting

RATE_LIMIT_RESULT_QUERIES=1

RATE_LIMIT_FEE_QUERIES=1



# Notification Expiry

NOTIFICATION_EXPIRY_DAYS=7



# Result Visibility

RESULT_VISIBILITY_DAYS=7



# Telegram Bot Configuration

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

TELEGRAM_BOT_WEBHOOK_URL=https://your-domain.com/webhook/telegram

ADMIN_TELEGRAM_CHAT_ID=your_admin_chat_id_here



# Bot Configuration

BOT_ENABLED=true

BOT_DEBUG=false

